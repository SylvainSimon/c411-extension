<div id="c411-mod-overlay" class="c411-overlay">
    <div class="c411-mod-window">
        <header class="c411-mod-header">
            <div class="c411-mod-logo">
                <svg viewBox="0 0 24 24" width="24" height="24"><path fill="currentColor" d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm0 10.99h7c-.53 4.12-3.28 7.79-7 8.94V12H5V6.3l7-3.11v8.8z"/></svg>
                <span>C411 Moderation Center</span>
            </div>
            <button id="c411-mod-close" class="c411-mod-close-btn">&times;</button>
        </header>
        
        <div class="c411-mod-body">
            <aside class="c411-mod-sidebar">
                <div class="sidebar-top">
                    <div class="form-group">
                        <label>Mode de contrôle</label>
                        <select id="c411-current-tool" class="c411-mod-input tool-select">
                            <option value="registration">🕒 Inscriptions</option>
                            <option value="leaderboard">🥇 Classements</option>
                        </select>
                    </div>

                    <div class="c411-mod-tabs">
                        <button class="c411-tab-btn active" data-tab="scan">Contrôles</button>
                        <button class="c411-tab-btn" data-tab="history">Sessions</button>
                    </div>
                </div>

                <div id="tab-scan-controls" class="tab-content">
                    <div id="tool-container"></div>
                </div>

                <div id="tab-history-controls" class="tab-content" style="display: none;">
                    <div class="c411-history-box">
                        <div class="form-group">
                            <label>Historique des analyses</label>
                            <select id="c411-session-selector" class="c411-mod-input"></select>
                        </div>
                        <div class="history-actions">
                            <button id="c411-delete-session" class="btn-outline-danger">Supprimer</button>
                            <button id="c411-clear-all-sessions" class="btn-link-danger">Vider tout</button>
                        </div>
                    </div>
                </div>

                <div class="c411-sidebar-footer">
                    <button id="c411-resume-scan" class="btn-pause" style="display: none;">
                        ▶ REPRENDRE LE SCAN
                    </button>
                    
                    <button id="c411-stop-scan" class="btn-pause" style="display: none;">
                        ⏸ PAUSE LE SCAN
                    </button>

                    <div id="c411-scan-progress-box" class="progress-container" style="display: none;">
                        <div class="progress-info">
                            <span id="c411-progress-text">0/0</span>
                            <span id="c411-progress-percent">0%</span>
                        </div>
                        <div class="progress-track"><div id="c411-progress-bar-fill" class="progress-fill"></div></div>
                    </div>
                    
                    <div id="c411-scan-status" class="scan-status">Prêt</div>
                </div>
            </aside>
            
            <main class="c411-mod-content">
                <header class="results-header">
                    <div class="header-main">
                        <h2 id="c411-current-title">Nouvelle Analyse</h2>
                        <div class="header-controls">
                            <div class="pattern-filters">
                                <span class="label">Filtrer :</span>
                                <button class="pat-btn" data-flag="late">🕒 Tardif</button>
                                <button class="pat-btn" data-flag="rank1">🥇 Rang #1</button>
                                <button class="pat-btn" data-flag="dominant">👑 Dominant</button>
                                <button class="pat-btn" data-flag="fast">🚀 Rapide</button>
                                <button class="pat-btn" data-flag="ratio">📊 Ratio</button>
                                <button class="pat-btn" data-flag="identical">🔄 Identique</button>
                                <button class="pat-btn" data-flag="onesnatch">🎯 1 Snatch</button>
                                <button class="pat-btn" data-flag="is_uploader">📤 Uploader</button>
                                <button class="pat-btn" data-flag="no_upload">🔇 0 Upload</button>
                                <button class="pat-btn" data-flag="high_impact">⚖️ Impact</button>
                            </div>
                            <div class="sort-group">
                                <span class="label">Trier par :</span>
                                <select id="c411-sort-by" class="c411-mod-input sort-select">
                                    <option value="">Par défaut (Reçus)</option>
                                    <option value="score_desc">🔥 Score (Max)</option>
                                    <option value="date_desc">📅 Date (Récent)</option>
                                    <option value="date_asc">📅 Date (Ancien)</option>
                                    <option value="speed_desc">🚀 Vitesse (Max)</option>
                                    <option value="ratio_desc">📊 Ratio (Max)</option>
                                    <option value="late_desc">🕒 Retard (Max)</option>
                                    <option value="impact_desc">⚖️ Impact (Max)</option>
                                </select>
                            </div>
                        </div>
                    </div>
                    
                    <div class="header-right">
                        <button id="c411-clean-list" class="btn-clean" title="Vérifier et retirer les membres déjà bannis de cette liste">✨ Retirer les bannis</button>
                        <div class="stats-group">
                            <div class="stat"><span id="c411-stat-total">0</span><span>Suspects</span></div>
                            <div class="stat danger"><span id="c411-stat-suspect">0</span><span>Moyens</span></div>
                            <div class="stat critical"><span id="c411-stat-critical">0</span><span>Critiques</span></div>
                        </div>
                    </div>
                </header>

                <div id="c411-limit-warning" class="alert-warning" style="display: none;">
                    Affichage limité aux 5 000 plus suspects.
                </div>
                
                <table class="c411-table">
                    <thead>
                        <tr>
                            <th>Utilisateur</th>
                            <th>Inscrit le</th>
                            <th>Score</th>
                            <th>Impact</th>
                            <th>Détections</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody id="c411-mod-results"></tbody>
                </table>
                <div id="c411-mod-empty" class="empty-state">Aucun profil suspect à afficher.</div>
            </main>
        </div>
    </div>
</div>

<style>
    :host {
        --primary: #8ab4f8; --primary-dark: #1a73e8; --secondary: #9aa0a6;
        --bg-window: #202124; --bg-body: #292a2d; --border: #3c4043;
        --text: #e8eaed; --danger: #f28b82; --danger-dark: #d93025;
        --warning: #fdd663;
    }

    .c411-overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.7); display: flex; align-items: center; justify-content: center; z-index: 1000000; font-family: system-ui, -apple-system, sans-serif; color: var(--text); }
    .c411-mod-window { width: 92vw; height: 88vh; background: var(--bg-window); border-radius: 12px; display: flex; flex-direction: column; overflow: hidden; border: 1px solid var(--border); box-shadow: 0 24px 64px rgba(0,0,0,0.5); }
    .c411-mod-header { background: var(--bg-window); color: var(--primary); padding: 14px 20px; display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid var(--border); }
