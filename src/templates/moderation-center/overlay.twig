    .header-main { display: flex; flex-direction: column; gap: 12px; }
    .header-controls { display: flex; flex-wrap: wrap; align-items: center; gap: 20px; }
    .results-header h2 { margin: 0; font-size: 1.3em; color: var(--primary); }
    
    .pattern-filters, .sort-group { display: flex; align-items: center; gap: 6px; }
