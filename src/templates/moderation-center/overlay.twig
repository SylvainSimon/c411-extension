    .pat-btn { background: #3c4043; border: 1px solid var(--border); color: var(--secondary); padding: 3px 10px; border-radius: 15px; font-size: 0.75em; cursor: pointer; }
    .pat-btn.active { background: var(--primary-dark); border-color: var(--primary); color: white; }

    .sort-select { padding: 4px 8px; font-size: 0.75em; border-radius: 15px; background: #3c4043; color: var(--primary); font-weight: bold; cursor: pointer; }

    .header-right { display: flex; flex-direction: column; align-items: flex-end; gap: 10px; }
