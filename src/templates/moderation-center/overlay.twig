    .progress-track { height: 4px; background: #3c4043; border-radius: 2px; overflow: hidden; }
    .progress-fill { height: 100%; background: var(--primary); width: 0%; transition: width 0.3s; }
    .scan-status { font-size: 0.75em; color: var(--secondary); padding: 8px; border-radius: 4px; background: rgba(255,255,255,0.02); text-align: center; }
    
    .c411-mod-content { flex: 1; padding: 24px; overflow-y: auto; background: var(--bg-body); display: flex; flex-direction: column; gap: 20px; }
