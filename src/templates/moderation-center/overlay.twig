    .stats-group { display: flex; gap: 10px; }
    .stat { background: var(--bg-window); padding: 8px 12px; border-radius: 6px; border: 1px solid var(--border); display: flex; flex-direction: column; align-items: center; min-width: 70px; }
    .stat span:first-child { font-size: 1.2em; font-weight: bold; line-height: 1; }
    .stat span:last-child { font-size: 0.65em; text-transform: uppercase; color: var(--secondary); margin-top: 4px; }
    .stat.danger span:first-child { color: var(--warning); }
