    .c411-mod-close-btn { background: none; border: none; color: var(--secondary); font-size: 24px; cursor: pointer; }
    
    .c411-mod-body { display: flex; flex: 1; overflow: hidden; }
    .c411-mod-sidebar { width: 280px; border-right: 1px solid var(--border); padding: 20px; background: var(--bg-window); display: flex; flex-direction: column; gap: 24px; }
    
    .sidebar-top { display: flex; flex-direction: column; gap: 15px; }
    .form-group { display: flex; flex-direction: column; gap: 6px; }
    .form-group label { font-size: 0.65em; color: var(--secondary); font-weight: 800; text-transform: uppercase; letter-spacing: 0.5px; }
    .c411-mod-input { padding: 8px 10px; background: #303134; border: 1px solid var(--border); border-radius: 6px; color: var(--text); font-size: 0.9em; outline: none; }

    .c411-mod-tabs { display: flex; background: #303134; border-radius: 6px; padding: 3px; }
    .c411-tab-btn { flex: 1; border: none; background: none; color: var(--secondary); padding: 6px; font-size: 0.8em; font-weight: bold; cursor: pointer; border-radius: 4px; }
    .c411-tab-btn.active { background: #3c4043; color: var(--primary); }

    .tab-content { flex: 1; }
    .c411-history-box { display: flex; flex-direction: column; gap: 12px; }
    .history-actions { display: flex; align-items: center; justify-content: space-between; }
    .btn-outline-danger { background: none; border: 1px solid var(--danger); color: var(--danger); padding: 5px 12px; border-radius: 4px; font-size: 0.8em; cursor: pointer; font-weight: bold; }
    .btn-link-danger { background: none; border: none; color: var(--secondary); font-size: 0.75em; cursor: pointer; text-decoration: underline; }

    .c411-sidebar-footer { margin-top: auto; display: flex; flex-direction: column; gap: 12px; padding-top: 15px; border-top: 1px solid var(--border); }
    .btn-resume { background: rgba(138, 180, 248, 0.1); border: 1px solid var(--primary); color: var(--primary); padding: 10px; border-radius: 6px; cursor: pointer; font-weight: bold; font-size: 0.8em; }
    .btn-pause { background: #3c4043; border: 1px solid var(--border); color: var(--text); padding: 10px; border-radius: 6px; cursor: pointer; font-weight: bold; font-size: 0.8em; }

    .progress-container { display: flex; flex-direction: column; gap: 6px; }
