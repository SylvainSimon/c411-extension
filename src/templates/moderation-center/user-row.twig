<tr class="c411-mod-user-row main-row" 
    data-user-id="{{ user.id }}" 
    data-score="{{ suspicionScore }}"
    data-flags="{{ filterFlags }}">
    <td>
        <div class="user-info">
            <div class="user-main">
                <span class="username">{{ user.username }}</span>
                {% if user.isTeam %}
                    <span class="team-badge">{{ user.teamName ?: 'TEAM' }}</span>
                {% endif %}
            </div>
            <div class="user-sub">
                <span class="user-id">#{{ user.id }}</span>
                {% if user.torrentsUploaded > 0 %}
                    <span class="user-uploads" title="Nombre de torrents uploadés">📤 {{ user.torrentsUploaded }}</span>
                {% endif %}
            </div>
        </div>
    </td>
    <td>{{ createdAtFormatted }}</td>
    <td>
        <span class="score-badge score-{{ suspicionLevel }}">
            {{ suspicionScore }}
        </span>
    </td>
    <td>
        <span class="impact-badge {% if impactPercent >= 50 %}impact-high{% endif %}" title="Impact de la triche sur l'upload total">
            {{ impactPercent }}%
        </span>
    </td>
    <td>
        <div class="detection-badges">
            {% if flags.late %}<span class="det-badge late" title="Plus long délai après publication">🕒 {{ flags.late }}</span>{% endif %}
            {% if flags.rank1 %}<span class="det-badge rank1" title="Rang #1 au classement">🥇 {{ flags.rank1 }}</span>{% endif %}
            {% if flags.dominant %}<span class="det-badge dominant" title="Domination sur un torrent">👑 {{ flags.dominant }}</span>{% endif %}
            {% if flags.fast %}<span class="det-badge fast" title="Débit maximum relevé">🚀 {{ flags.fast }}</span>{% endif %}
            {% if flags.ratio %}<span class="det-badge ratio" title="Ratio maximum sur un torrent">📊 {{ flags.ratio }}</span>{% endif %}
            {% if flags.identical %}<span class="det-badge identical" title="Uploads identiques synchronisés">🔄 {{ flags.identical }}</span>{% endif %}
        </div>
    </td>
    <td>
        <div class="row-actions">
            <a href="/user/{{ user.username }}" target="_blank" class="c411-mod-btn-small" title="Ouvrir le profil" onclick="event.stopPropagation()">👤</a>
            {% if suspicionLevel == 'critical' or suspicionLevel == 'high' %}
                <button class="c411-mod-btn-small danger ban-user" 
                        data-user-id="{{ user.id }}" 
                        data-username="{{ user.username }}"
                        data-reason="{{ banReason }}"
                        title="Bannir"
                        onclick="event.stopPropagation()">🚫</button>
            {% endif %}
            <span class="accordion-chevron">▼</span>
        </div>
    </td>
</tr>
<tr class="c411-mod-user-row detail-row" data-user-id="{{ user.id }}" style="display: none;">
    <td colspan="5">
        <div class="accordion-content">
            <div class="analysis-summary">
                {% if analysis.globalWarnings|length > 0 %}
                <div class="warnings-section">
                    <span class="section-title">⚠️ ALERTES GLOBALES :</span>
                    <ul>
                        {% for warning in analysis.globalWarnings %}
                        <li>{{ warning }}</li>
                        {% endfor %}
                    </ul>
                </div>
                {% endif %}

                <div class="torrents-section">
                    <span class="section-title">📂 TORRENTS SUSPECTS ({{ analysis.suspiciousTorrents|length }}) :</span>
                    <div class="torrents-grid">
                        {% for t in analysis.suspiciousTorrents|slice(0, 10) %}
                        <div class="torrent-mini-card">
                            <span class="t-name" title="{{ t.name }}">{{ t.name }}</span>
                            <div class="t-stats">
                                <span class="t-badge ratio">Ratio {{ t.actualRatioFormatted }}</span>
                                <span class="t-badge speed">{{ t.uploadSpeedFormatted }}</span>
                                {% if t.isDominant %}<span class="t-badge dom">Dom. {{ t.dominanceRatio }}x</span>{% endif %}
                                {% if t.isLateActivity %}<span class="t-badge late">+{{ t.delayFromCreationDays|round }}j</span>{% endif %}
                            </div>
                        </div>
                        {% endfor %}
                        {% if analysis.suspiciousTorrents|length > 10 %}
                        <div class="more-torrents">... et {{ analysis.suspiciousTorrents|length - 10 }} autres</div>
                        {% endif %}
                    </div>
                </div>

                <div class="ban-synthese">
                    <span class="section-title">📝 SYNTHÈSE PREUVES :</span>
                    <div class="synthese-text">{{ banReason }}</div>
                </div>
            </div>
        </div>
    </td>
</tr>

<style>
    .c411-mod-user-row.main-row { cursor: pointer; transition: background 0.2s; }
    .c411-mod-user-row.main-row:hover { background: rgba(138, 180, 248, 0.05); }
    .c411-mod-user-row.main-row.active { background: rgba(138, 180, 248, 0.1); border-left: 3px solid var(--primary); }
    
    .detail-row { background: #292a2d; border-top: 1px solid var(--border); }
    .accordion-content { padding: 15px 20px; border-left: 3px solid var(--primary); }
    
    .section-title { font-size: 0.65em; font-weight: 800; color: var(--secondary); text-transform: uppercase; letter-spacing: 1px; display: block; margin-bottom: 8px; }
    
    .warnings-section { margin-bottom: 15px; }
    .warnings-section ul { margin: 0; padding-left: 20px; color: var(--danger); font-size: 0.85em; }
    .warnings-section ul li { white-space: pre-line; margin-bottom: 4px; }
    
    .torrents-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 10px; margin-bottom: 15px; }
    .torrent-mini-card { background: #303134; padding: 8px 12px; border-radius: 6px; border: 1px solid var(--border); display: flex; flex-direction: column; gap: 6px; }
    .t-name { font-size: 0.8em; font-weight: bold; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; color: var(--text); }
    .t-stats { display: flex; gap: 5px; flex-wrap: wrap; }
    .t-badge { font-size: 0.65em; padding: 1px 5px; border-radius: 3px; font-weight: bold; }
    .t-badge.ratio { background: rgba(242, 139, 130, 0.2); color: #f28b82; }
    .t-badge.speed { background: rgba(129, 201, 149, 0.2); color: #81c995; }
    .t-badge.dom { background: rgba(253, 214, 99, 0.2); color: #fdd663; }
    .t-badge.late { background: rgba(138, 180, 248, 0.2); color: #8ab4f8; }
    
    .synthese-text { font-size: 0.85em; background: rgba(0,0,0,0.2); padding: 10px; border-radius: 4px; border-left: 2px solid var(--secondary); color: var(--secondary); font-style: italic; }
    
    .score-container { display: flex; flex-direction: column; align-items: center; gap: 4px; }
    .score-badge { padding: 4px 10px; border-radius: 6px; font-weight: 900; font-size: 0.9em; min-width: 35px; text-align: center; }
    .score-badge.score-critical { background: rgba(217, 48, 37, 0.15); color: #f28b82; border: 1px solid rgba(217, 48, 37, 0.3); }
    .score-badge.score-high { background: rgba(232, 113, 10, 0.15); color: #fb923c; border: 1px solid rgba(232, 113, 10, 0.3); }
    .score-badge.score-medium { background: rgba(250, 204, 21, 0.15); color: #fcc934; }
    .score-badge.score-low { background: rgba(138, 180, 248, 0.15); color: #8ab4f8; }

    .impact-badge { font-size: 0.65em; font-weight: bold; color: var(--secondary); opacity: 0.8; border: 1px solid var(--border); padding: 1px 4px; border-radius: 4px; }
    .impact-badge.impact-high { color: var(--danger); border-color: var(--danger); opacity: 1; }

    .user-info { display: flex; flex-direction: column; gap: 2px; }
    .user-main { display: flex; align-items: center; gap: 6px; }
    .user-sub { display: flex; align-items: center; gap: 10px; }
    
    .username { font-weight: bold; color: var(--primary); }
    .team-badge { background: #fdd663; color: #202124; font-size: 0.6em; font-weight: 900; padding: 1px 4px; border-radius: 3px; letter-spacing: 0.5px; }
    
    .user-id { font-size: 0.75em; color: var(--secondary); font-family: monospace; }
    .user-uploads { font-size: 0.75em; color: #81c995; font-weight: bold; }
    
    .detection-badges { display: flex; flex-wrap: wrap; gap: 6px; }
    .det-badge { padding: 2px 8px; border-radius: 4px; font-size: 0.75em; font-weight: bold; text-transform: uppercase; border: 1px solid rgba(255,255,255,0.1); }
    
    .det-badge.late { background: rgba(138, 180, 248, 0.15); color: #8ab4f8; }
    .det-badge.rank1 { background: rgba(255, 215, 0, 0.1); color: #ffd700; border-color: rgba(255, 215, 0, 0.3); }
    .det-badge.dominant { background: rgba(253, 214, 99, 0.15); color: #fdd663; }
    .det-badge.fast { background: rgba(129, 201, 149, 0.15); color: #81c995; }
    .det-badge.ratio { background: rgba(242, 139, 130, 0.15); color: #f28b82; }
    .det-badge.identical { background: #8ab4f8; color: #202124; }

    .row-actions { display: flex; gap: 8px; }
    .c411-mod-btn-small { padding: 6px 10px; border: 1px solid var(--border); background: #3c4043; color: var(--text); border-radius: 6px; cursor: pointer; text-decoration: none; display: inline-flex; align-items: center; justify-content: center; }
    .c411-mod-btn-small.danger { color: var(--danger); border-color: var(--danger); }
    .c411-mod-btn-small:hover { background: #4f5256; }

    .accordion-chevron { color: var(--secondary); font-size: 0.8em; margin-left: 5px; transition: transform 0.3s; pointer-events: none; }
    .main-row.active .accordion-chevron { transform: rotate(180deg); color: var(--primary); }
</style>
